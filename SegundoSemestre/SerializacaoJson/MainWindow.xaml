<Window x:Class="SerializacaoJson.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciador de Pessoas (JSON)" Height="500" Width="700"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cadastro e Leitura em JSON" 
                   Grid.Row="0" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#1E293B" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Nome da Pessoa:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="EntradaNome" Width="250" Height="32" Padding="5" VerticalContentAlignment="Center" BorderBrush="#CBD5E1" BorderThickness="1"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Idade:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                    <TextBox x:Name="EntradaIdade" Width="100" Height="32" Padding="5" VerticalContentAlignment="Center" BorderBrush="#CBD5E1" BorderThickness="1"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="Salvar em JSON" 
                    Click="SalvarBtn_Click" 
                    Width="140" Height="38" 
                    Margin="0,0,15,0" 
                    Background="#10B981" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>

            <Button Content="Carregar JSON" 
                    Click="GetPessoa_Click" 
                    Width="140" Height="38" 
                    Background="#3B82F6" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10">
            <DataGrid x:Name="DataExibido" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#F1F5F9"
                      BorderThickness="0">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                    <DataGridTextColumn Header="Idade" Binding="{Binding Idade}" Width="100"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>

    </Grid>
</Window>