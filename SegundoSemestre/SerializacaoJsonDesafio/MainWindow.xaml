<Window x:Class="SerializacaoJsonDesafio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciamento de Pessoas (JSON)" Height="450" Width="750"
        Background="#F1F5F9" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Adicionar Pessoa" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Nome:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtNome" Height="28" Margin="0,0,0,10" Padding="4"/>

                <TextBlock Text="Idade:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtIdade" Height="28" Margin="0,0,0,15" Padding="4"/>

                <Button Content="1. Adicionar Pessoa" Click="BtnAdicionar_Click" Height="35" Background="#22C55E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Center">
                <Button Content="2. Atualizar Lista" Click="BtnListar_Click" Width="110" Height="35" Margin="5" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="3. Salvar em JSON" Click="BtnSalvar_Click" Width="120" Height="35" Margin="5" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="4. Carregar do JSON" Click="BtnCarregar_Click" Width="130" Height="35" Margin="5" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="5. Sair" Click="BtnSair_Click" Width="70" Height="35" Margin="5" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </WrapPanel>

            <DataGrid x:Name="dgPessoas" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F8FAFC" BorderBrush="#E2E8F0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                    <DataGridTextColumn Header="Idade" Binding="{Binding Idade}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>